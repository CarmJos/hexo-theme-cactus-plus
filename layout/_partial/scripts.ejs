<!-- jquery -->
<%- js('lib/jquery/jquery.min.js') %>
<%- js('lib/justified-gallery/js/jquery.justifiedGallery.min.js') %>
<!-- clipboard -->
<% if (is_post()){ %>
    <%- js('lib/clipboard/clipboard.min.js') %>
    <script type="text/javascript">
        $(function () {
            // copy-btn HTML
            var btn = "<span class=\"btn-copy tooltipped tooltipped-sw\" aria-label=\"<%= __('tooltip.copy_tip') %>\">";
            btn += '<i class="far fa-clone"></i>';
            btn += '</span>';
            // mount it!
            $(".highlight .code pre").before(btn);
            var clip = new ClipboardJS('.btn-copy', {
                target: function (trigger) {
                    return trigger.nextElementSibling;
                }
            });
            clip.on('success', function (e) {
                e.trigger.setAttribute('aria-label', "<%= __('tooltip.copied') %>");
                e.clearSelection();
            })
        })
    </script>
<% } %>
<%- js('js/main') %>
<!-- search -->
<% if (config.search && (page.search || page.type === "search")){ %>
    <%- js('js/search.js') %>
    <script type="text/javascript">
        $(function () {

            var $inputArea = $("input#search-input");
            var $resultArea = document.querySelector("div#search-result");
            var $noResultTip = $(".search-no-result");

            function updateNoResultState() {
                var hasInput = $inputArea.val().trim().length > 0;
                var hasResults = $resultArea.querySelectorAll("li").length > 0;
                if (hasInput && !hasResults) {
                    $noResultTip.show(200);
                } else {
                    $noResultTip.hide();
                }
            }

            $inputArea.focus(function () {
                var search_path = "<%= config.search.path %>";
                if (search_path.length == 0) {
                    search_path = "search.xml";
                }
                var path = "<%= config.root %>" + search_path;
                searchFunc(path, 'search-input', 'search-result');
            });

            $inputArea.keydown(function (e) {
                if (e.which == 13) {
                    e.preventDefault();
                }
            });

            $inputArea.on("input", updateNoResultState);

            var observer = new MutationObserver(function () {
                updateNoResultState();
            });

            observer.observe($resultArea, {childList: true, subtree: true});
            updateNoResultState();

        });
    </script>
<% } %>
